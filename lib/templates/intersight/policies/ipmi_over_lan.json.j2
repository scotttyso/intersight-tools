{
    "Description": "{{ description | default('') }}",
    "Enabled": "{{ enabled | default(true) | bool }}",
{%- if encryption_key is defined -%}
    "EncryptionKey": "{{ encryption_key }}",
{%- endif -%}
    "Name": "{{ name | default('default') }}",
    "Organization": {
        "Moid": "{{ org_moids[organization].moid }}",
        "ObjectType": "organization.Organization"
    },
    "Privilege": "{{ privilege | default('read-only') }}",
{% if tags is defined %}
    "Tags": [
  {%- for tag in tags -%}
        {
            "Key": "{{ tag.key }}",
            "Value": "{{ tag.value }}"
        }{% if not loop.last %},{% endif %}
  {%- endfor -%}
    ]
{%- else %}
    "Tags": []
{%- endif %}
}