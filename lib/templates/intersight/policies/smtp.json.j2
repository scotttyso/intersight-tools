{
    "ApplianceAccount": null,
    "Certificate": null,
    "Description": "{{ description | default('') }}",
    "EnableAuth": false,
    "EnableTls": false,
    "Enabled": {{ enable_smtp | default(true) | bool }},
    "IsAuthPasswordSet": false,
    "MinSeverity": "{{ minimum_severity | default('critical') }}",
    "Name": "{{ name | default('default') }}",
    "Organization": {
        "Moid": "{{ org_moids[organization].moid }}",
        "ObjectType": "organization.Organization"
    },
    "SenderEmail": "{{ smtp_alert_sender_address | default('intersight@example.com') }}",
    "SmtpPort": {{ smtp_port | default(25) }},
    "SmtpRecipients": [
{%- for item in mail_alert_recipients %}
        "{{ item }}"{% if not loop.last %},{% endif %}
{%- endfor %}
    ],
    "SmtpServer": "{{ smtp_server_address | default('smtp.example.com') }}",
{% if tags is defined %}
    "Tags": [
  {%- for tag in tags -%}
        {
            "Key": "{{ tag.key }}",
            "Value": "{{ tag.value }}"
        }{% if not loop.last %},{% endif %}
  {%- endfor -%}
    ],
{%- endif %}
    "UserName": ""
}