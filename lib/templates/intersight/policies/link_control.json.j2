{
    "Description": "{{ description | default('') }}",
    "Name": "{{ name | default('default') }}",
    "Organization": {
        "Moid": "{{ org_moids[organization].moid }}",
        "ObjectType": "organization.Organization"
    },
{% if tags is defined %}
    "Tags": [
  {%- for tag in tags -%}
        {
            "Key": "{{ tag.key }}",
            "Value": "{{ tag.value }}"
        }{% if not loop.last %},{% endif %}
  {%- endfor -%}
    ]
{%- else %}
    "Tags": [],
{%- endif %}
    "UdldSettings": {
        "AdminState": "{{ admin_state | default('Enabled') }}",
        "ClassId": "fabric.UdldSettings",
        "Mode": "{{ mode | default('normal') }}",
        "ObjectType": "fabric.UdldSettings"
    }
}