    },
    "IncludeIcvIndicator": false,
    "KeyServerPriority": 16,
    "MacSecEaPol": {
        "ClassId": "fabric.MacSecEaPol",
        "EaPolEthertype": "0x888e",
        "EaPolMacAddress": "0180.C200.0003",
        "ObjectType": "fabric.MacSecEaPol"
    },
    "Description": "{{ description | default('') }}",
