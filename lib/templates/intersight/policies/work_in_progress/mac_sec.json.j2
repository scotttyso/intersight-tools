                "SendLifetimeDuration": 0,
                "SendLifetimeEndTime": "0001-01-01T00:00:00Z",
                "SendLifetimeInfinite": false,
                "SendLifetimeStartTime": "0001-01-01T00:00:00Z",
                "SendLifetimeTimeZone": "UTC",
                "SendLifetimeUnlimited": true
            }
        ]
    },
    "ReplayWindowSize": 148809600,
    "SakExpiryTime": 0,
    "SecurityPolicy": "Should-secure",
{% if tags is defined %}
    "Tags": [
  {%- for tag in tags -%}
        {
            "Key": "{{ tag.key }}",
            "Value": "{{ tag.value }}"
        }{% if not loop.last %},{% endif %}
  {%- endfor -%}
    ]
{%- endif %}
