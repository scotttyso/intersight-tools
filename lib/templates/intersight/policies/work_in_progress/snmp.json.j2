{
    "AccessCommunityString": "",
    "CommunityAccess": "Disabled",
    "Description": "snmp SNMP Policy",
    "Enabled": true,
    "EngineId": "",
    "Description": "{{ description | default('') }}",
    "Name": "{{ name | default('default') }}",
    "Organization": {
        "Moid": "{{ org_moids[organization].moid }}",
        "ObjectType": "organization.Organization"
    },
    "SnmpPort": 161,
    "SnmpTraps": [],
    "SnmpUsers": [],
    "SysContact": "",
    "SysLocation": "",
{% if tags is defined %}
    "Tags": [
  {%- for tag in tags -%}
        {
            "Key": "{{ tag.key }}",
            "Value": "{{ tag.value }}"
        }{% if not loop.last %},{% endif %}
  {%- endfor -%}
    ],
{%- endif %}
    "TrapCommunity": "",
    "V2Enabled": false,
    "V3Enabled": false
}