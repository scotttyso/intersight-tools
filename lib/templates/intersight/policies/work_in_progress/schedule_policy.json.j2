{
    "AssociatedObjects": [],
    "BlockDates": [],
    "Description": "{{ description | default('') }}",
    "EnableBlockDates": {{ enable_block_dates | default(false) | bool }},
    "Name": "{{ name | default('default') }}",
    "Organization": {
        "Moid": "{{ org_moids[organization].moid }}",
        "ObjectType": "organization.Organization"
    },
    "ScheduleParams": [
        {
            "ClassId": "scheduler.OneTimeScheduleParams",
            "Duration": "PT1H",
            "Name": "web",
            "ObjectType": "scheduler.OneTimeScheduleParams",
            "StartTime": "2026-02-18T09:00:00Z",
            "TimeZone": "America/Anchorage"
        }
    ],
{% if tags is defined %}
    "Tags": [
  {%- for tag in tags -%}
        {
            "Key": "{{ tag.key }}",
            "Value": "{{ tag.value }}"
        }{% if not loop.last %},{% endif %}
  {%- endfor -%}
    ]
{%- else %}
    "Tags": []
{%- endif %}
}