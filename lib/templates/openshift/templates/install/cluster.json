{
    "api": "{{ api_vip }}",
    "base_dns_domain": "{{ cluster_domain }}",
    "cluster_network_cidr": "{{ cluster_network_cidr | default('10.128.0.0/14') }}",
    "cluster_network_host_prefix": "{{ cluster_network_host_prefix | default(23) }}",
    "cpu_architecture": "{{ cpu_architecture | default('x86_64') }}",
    "dns_ip": "{{ dns_servers }}",
    "ingress": "{{ ingress_vip }}",
    "iso": "{{ iso | default('full') }}",
    "machine_network_gateway": "{{ machine_network_gateway }}",
    "name": "{{ cluster_name }}",
    "network_type": "{{ network_type | default('OVNKubernetes') }}",
    "ntp": "{{ ntp_servers }}",
    "openshift_version": "{{ cluster_version | default('4.19.16') }}",
    "service_network_cidr": "{{ service_network_cidr | default('172.132.0.0/16') }}"
}