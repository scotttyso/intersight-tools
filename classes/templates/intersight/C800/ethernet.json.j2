{# /redfish/v1/Managers/bmc/EthernetInterfaces/eth0 #}
{
    "DHCPv4": {
        "DHCPEnabled": false,
        "UseDNSServers": {% if item.dns_servers | default([]) %}false{% else %}true{% endif %},
        "UseDomainName": {% if item.domain_name %}false{% else %}true{% endif %},
        "UseNTPServers": {% if item.ntp_servers | default([]) %}false{% else %}true{% endif %}
    },
    "DomainName": "{{ item.domain_name }}",
    "HostName": "{{ item.hostname }}",
{% if item.ipv4 is defined %}
{% set _ipv4 = item.ipv4 %}
    "IPv4StaticAddresses": [
        {
            "Address": "{{ _ipv4.address }}",
            "Gateway": "{{ _ipv4.gateway }}",
            "SubnetMask": "{{ _ipv4.netmask }}"
        }
    ],
{% endif %}
{% if item.ipv6 is defined %}
{% set _ipv6 = item.ipv6 %}
    "IPv6StaticDefaultGateways": [
        "{{ _ipv6.gateway }}"
    ],
    "IPv6StaticAddresses": [
        {
            "Address": "{{ _ipv6.address }}",
            "SubnetMask": "{{ _ipv6.netmask }}"
        }
    ],
{% endif %}
    "StaticNameServers": [
{% for dns_server in item.dns_servers | default([]) %}
        "{{ dns_server }}"{% if not loop.last %},{% endif %}
{% endfor %}
    ]
}