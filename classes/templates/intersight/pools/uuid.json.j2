{
  "AssignmentOrder": "{{  item.assignment_order | default('sequential') }}",
  "Description": "{{ item.description | default('') }}",
  "Name": "{{ name_prefix ~ item.name ~ name_suffix }}",
  "ObjectType": "uuidpool.Pool",
  "Organization": {
    "Moid": "{{ org_moids[organization].moid }}",
    "ObjectType": "organization.Organization"
  },
  "Prefix": "{{ item.prefix | default('000025B5-0000-0000') }}",
{% if item.tags | length > 0 %}
  "Tags": [
{% for tag in item.tags %}
    {
{% if tag.tag_type | default('KeyValue') == 'PathTag' %}
      "Key": "{{ tag.key }}",
      "Type": "PathTag"
{% else %}
      "Key": "{{ tag.key }}",
      "Type": "KeyValue",
      "Value": "{{ tag.value }}"
{% endif %}
    }{% if not loop.last %},{% endif %}
{% endfor %}
  ],
{% else %}
  "Tags": [],
{% endif %}
  "UuidSuffixBlocks": [
{% if item.id_blocks is defined and item.id_blocks | length > 0 %}
{% for block in item.id_blocks %}
    {
      "From": "{{ block.from | default('0000-000000000000') }}",
      "ObjectType": "uuidpool.UuidBlock",
{% if block.to is defined %}
      "To": "{{ block.to | default('0000-0000000000FF') }}"
{% else %}
      "Size": {{ block.size | default(255) }}
{% endif %}
    }{% if not loop.last %},{% endif %}
{% endfor %}
{% endif %}
  ]
}