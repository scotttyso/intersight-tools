{
  "Description": {{ (item.description | default('', true)) | tojson }},
  "KeySetting": {
    "KeyType": "Kmip",
    "ManualKey": null,
    "ObjectType": "storage.KeySetting",
    "RemoteKey": {
      "AuthCredentials": {
        "IsPasswordSet": true,
        "ObjectType": "storage.KmipAuthCredentials",
        "UseAuthentication": true,
        "Username": "kmip_user"
      },
      "IsExistingKeySet": false,
      "ObjectType": "storage.RemoteKeySetting",
      "PrimaryServer": {
        "EnableDriveSecurity": true,
        "IpAddress": "kmip-primary.example.com",
        "ObjectType": "storage.KmipServer",
        "Port": 5696,
        "Timeout": 60
      },
      "SecondaryServer": {
        "EnableDriveSecurity": true,
        "IpAddress": "kmip-secondary.example.com",
        "ObjectType": "storage.KmipServer",
        "Port": 5696,
        "Timeout": 60
      },
      "ServerCertificate": ""
    }
  },
  "Name": {{ (name_prefix ~ item.name ~ name_suffix) | tojson }},
  "ObjectType": "storage.DriveSecurityPolicy",
  "Organization": {
    "Moid": "{{ org_moids[organization].moid }}",
    "ObjectType": "organization.Organization"
  },
{% if item.tags | length > 0 %}
  "Tags": [
{% for tag in item.tags %}
    {
{% if tag.tag_type | default('KeyValue') == 'PathTag' %}
      "Key": {{ tag.key | tojson }},
      "Type": "PathTag"
{% else %}
      "Key": {{ tag.key | tojson }},
      "Type": "KeyValue",
      "Value": {{ tag.value | tojson }}
{% endif %}
    }{% if not loop.last %},{% endif %}
{% endfor %}
  ]
{% else %}
  "Tags": []
{% endif %}
}
