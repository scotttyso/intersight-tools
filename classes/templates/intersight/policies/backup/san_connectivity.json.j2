{
  "Description": "{{ item.description | default('') }}",
  "Name": "scp-vic-gen4:mlom",
  "ObjectType": "vnic.SanConnectivityPolicy",
  "Organization": {
  "Moid": "{{ org_moids[organization].moid }}",
  "ObjectType": "organization.Organization"
  },
  "PlacementMode": "custom",
  "StaticWwnnAddress": "",
{% if item.tags | length > 0 %}
  "Tags": [
{% for tag in item.tags %}
    {
{% if tag.tag_type | default('KeyValue') == 'PathTag' %}
      "Key": "{{ tag.key }}",
      "Type": "PathTag"
{% else %}
      "Key": "{{ tag.key }}",
      "Type": "KeyValue",
      "Value": "{{ tag.value }}"
{% endif %}
    }{% if not loop.last %},{% endif %}
{% endfor %}
  ],
{% else %}
  "Tags": [],
{% endif %}
  "TargetPlatform": "{{ item.target_platform | default('FIAttached') }}",
  "WwnnAddressType": "POOL",
  "WwnnPool": {
    "Moid": "6467a417696275310148c6da",
    "ObjectType": "fcpool.Pool"
  }
}