{
  "Description": "{{ item.description | default('') }}",
  "LocalClients": [
    {
      "MinSeverity": "warning",
      "ObjectType": "syslog.LocalFileLoggingClient"
    }
  ],
  "Name": "{{ name_prefix ~ item.name ~ name_suffix }}",
  "ObjectType": "syslog.Policy",
  "Organization": {
    "Moid": "{{ org_moids[organization].moid }}",
    "ObjectType": "organization.Organization"
  },
  "RemoteClients": [
    {
      "Enabled": true,
      "Facility": "",
      "Hostname": "10.101.128.24",
      "MinSeverity": "informational",
      "ObjectType": "syslog.RemoteLoggingClient",
      "Port": 514,
      "Protocol": "udp",
      "VrfName": ""
    },
    {
      "Enabled": true,
      "Facility": "",
      "Hostname": "10.101.128.25",
      "MinSeverity": "informational",
      "ObjectType": "syslog.RemoteLoggingClient",
      "Port": 514,
      "Protocol": "udp",
      "VrfName": ""
    }
  ],
{% if item.tags | length > 0 %}
  "Tags": [
{% for tag in item.tags %}
    {
{% if tag.tag_type | default('KeyValue') == 'PathTag' %}
      "Key": "{{ tag.key }}",
      "Type": "PathTag"
{% else %}
      "Key": "{{ tag.key }}",
      "Type": "KeyValue",
      "Value": "{{ tag.value }}"
{% endif %}
    }{% if not loop.last %},{% endif %}
{% endfor %}
  ]
{% else %}
  "Tags": []
{% endif %}
}
