{
  "AllocatedBudget": 0,
  "Description": "{{ item.description | default('') }}",
  "DynamicRebalancing": "Enabled",
  "ExtendedPowerCapacity": "Enabled",
  "Name": "{{ name_prefix ~ item.name ~ name_suffix }}",
  "ObjectType": "power.Policy",
  "Organization": {
    "Moid": "{{ org_moids[organization].moid }}",
    "ObjectType": "organization.Organization"
  },
  "PowerPriority": "Low",
  "PowerProfiling": "Enabled",
  "PowerRestoreState": "LastState",
  "PowerSaveMode": "Enabled",
  "ProcessorPackagePowerLimit": "Default",
  "RedundancyMode": "Grid",
{% if item.tags | length > 0 %}
  "Tags": [
{% for tag in item.tags %}
    {
{% if tag.tag_type | default('KeyValue') == 'PathTag' %}
      "Key": "{{ tag.key }}",
      "Type": "PathTag"
{% else %}
      "Key": "{{ tag.key }}",
      "Type": "KeyValue",
      "Value": "{{ tag.value }}"
{% endif %}
    }{% if not loop.last %},{% endif %}
{% endfor %}
  ]
{% else %}
  "Tags": []
{% endif %}
}
