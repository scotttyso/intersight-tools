{
  "BaseProperties": {
    "Attribute": "memberof",
    "BaseDn": "DC=rich,DC=ciscolabs,DC=com",
    "BindDn": "CN=Tyson Scott,OU=Cisco Employees,DC=rich,DC=ciscolabs,DC=com",
    "BindMethod": "ConfiguredCredentials",
    "Domain": "rich.ciscolabs.com",
    "EnableEncryption": false,
    "EnableGroupAuthorization": false,
    "EnableNestedGroupSearch": true,
    "Filter": "sAMAccountName=$userid",
