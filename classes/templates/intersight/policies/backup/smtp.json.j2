{
  "ApplianceAccount": null,
  "Certificate": null,
  "Description": "{{ item.description | default('') }}",
  "EnableAuth": false,
  "EnableTls": false,
  "Enabled": true,
  "IsAuthPasswordSet": false,
  "MinSeverity": "critical",
  "Name": "{{ name_prefix ~ item.name ~ name_suffix }}",
  "ObjectType": "smtp.Policy",
  "Organization": {
    "Moid": "{{ org_moids[organization].moid }}",
    "ObjectType": "organization.Organization"
  },
  "SenderEmail": "intersight@example.com",
  "SmtpPort": 25,
  "SmtpRecipients": [
    "admin@example.com",
    "infra-ops@example.com"
  ],
  "SmtpServer": "mail.example.com",
{% if item.tags | length > 0 %}
  "Tags": [
{% for tag in item.tags %}
    {
{% if tag.tag_type | default('KeyValue') == 'PathTag' %}
      "Key": "{{ tag.key }}",
      "Type": "PathTag"
{% else %}
      "Key": "{{ tag.key }}",
      "Type": "KeyValue",
      "Value": "{{ tag.value }}"
{% endif %}
    }{% if not loop.last %},{% endif %}
{% endfor %}
  ],
{% else %}
  "Tags": [],
{% endif %}
  "UserName": ""
}
