{
  "Burst": {{ item.burst | default(10240) | int }},
  "Cos": {{ item.class_of_service | default(3) | int }},
  "Description": {{ (item.description | default('', true)) | tojson }},
  "MaxDataFieldSize": {{ item.max_data_field_size | default(2112) | int }},
  "Name": {{ (name_prefix ~ item.name ~ name_suffix) | tojson }},
  "ObjectType": "vnic.FcQosPolicy",
  "Organization": {
    "Moid": "{{ org_moids[organization].moid }}",
    "ObjectType": "organization.Organization"
  },
  "Priority": "FC",
  "RateLimit": {{ item.rate_limit | default(0) | int }},
{% if item.tags | length > 0 %}
  "Tags": [
{% for tag in item.tags %}
    {
{% if tag.tag_type | default('KeyValue') == 'PathTag' %}
      "Key": {{ tag.key | tojson }},
      "Type": "PathTag"
{% else %}
      "Key": {{ tag.key | tojson }},
      "Type": "KeyValue",
      "Value": {{ tag.value | tojson }}
{% endif %}
    }{% if not loop.last %},{% endif %}
{% endfor %}
  ]
{% else %}
  "Tags": []
{% endif %}
}
