{
  "Description": "{{ item.description | default('') }}",
  "Name": "{{ name_prefix ~ item.name ~ name_suffix }}",
  "ObjectType": "vnic.EthNetworkPolicy",
  "Organization": {
    "Moid": "{{ org_moids[organization].moid }}",
    "ObjectType": "organization.Organization"
  },
{% if item.tags | length > 0 %}
  "Tags": [
{% for tag in item.tags %}
    {
{% if tag.tag_type | default('KeyValue') == 'PathTag' %}
      "Key": "{{ tag.key }}",
      "Type": "PathTag"
{% else %}
      "Key": "{{ tag.key }}",
      "Type": "KeyValue",
      "Value": "{{ tag.value }}"
{% endif %}
    }{% if not loop.last %},{% endif %}
{% endfor %}
  ],
{% else %}
  "Tags": [],
{% endif %}
  "TargetPlatform": "{{ item.target_platform | default('Standalone') }}",
  "VlanSettings": {
    "AllowedVlans": "",
    "DefaultVlan": {{ item.default_vlan | default(0) }},
    "Mode": "{{ item.vlan_mode | default('ACCESS') }}",
    "ObjectType": "vnic.VlanSettings",
    "QinqEnabled": {% if item.qinq_vlan is defined %}true{% else %}false{% endif %},
    "QinqVlan": {{ item.qinq_vlan | default(2) }}
  }
}