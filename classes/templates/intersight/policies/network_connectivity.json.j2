{
{% set v4 = item.dns_servers_v4 | default([]) %}
{% set v6 = item.dns_servers_v6 | default([]) %}
  "AlternateIpv4dnsServer": {% if v4 | length > 1 %}"{{ v4[1] }}"{% else %}"0.0.0.0"{% endif %},
  "AlternateIpv6dnsServer": {% if v6 | length > 1 %}"{{ v6[1] }}"{% else %}"::"{% endif %},
  "Description": "{{ item.description | default('') }}",
  "DynamicDnsDomain": "{{ item.update_domain | default('') }}",
  "EnableDynamicDns": {{ item.enable_dynamic_dns | default(false) | lower }},
  "EnableIpv4dnsFromDhcp": {{ item.obtain_ipv4_dns_from_dhcp | default(false) | lower }},
  "EnableIpv6": {% if v6 | length > 0 or item.obtain_ipv6_dns_from_dhcp | default(false) %}true{% else %}false{% endif %},
  "EnableIpv6dnsFromDhcp": {{ item.obtain_ipv6_dns_from_dhcp | default(false) | lower }},
  "Name": "{{ name_prefix ~ item.name ~ name_suffix }}",
  "ObjectType": "networkconfig.Policy",
  "Organization": {
    "Moid": "{{ org_moids[organization].moid }}",
    "ObjectType": "organization.Organization"
  },
  "PreferredIpv4dnsServer": {% if v4 | length > 0 %}"{{ v4[0] }}"{% else %}"0.0.0.0"{% endif %},
  "PreferredIpv6dnsServer": {% if v6 | length > 0 %}"{{ v6[0] }}"{% else %}"::"{% endif %},
{% if item.tags | length > 0 %}
  "Tags": [
{% for tag in item.tags %}
    {
{% if tag.tag_type | default('KeyValue') == 'PathTag' %}
      "Key": "{{ tag.key }}",
      "Type": "PathTag"
{% else %}
      "Key": "{{ tag.key }}",
      "Type": "KeyValue",
      "Value": "{{ tag.value }}"
{% endif %}
    }{% if not loop.last %},{% endif %}
{% endfor %}
  ]
{% else %}
  "Tags": []
{% endif %}
}
