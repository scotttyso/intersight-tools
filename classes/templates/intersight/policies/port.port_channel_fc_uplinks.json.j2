{
  "AdminSpeed": {{ item.admin_speed | default('32Gbps') | tojson }},
  "FillPattern": {{ item.fill_pattern | default('Idle') | tojson }},
  "ObjectType": "fabric.FcUplinkPcRole",
  "PcId": {{ item.pc_id | default(1) }},
  "PortPolicy": {
    "Moid": "{{ isight[organization]['policies']['port'][item.parent] }}",
    "ObjectType": "fabric.PortPolicy"
  },
  "Ports": [
{% if item.interfaces is defined and item.interfaces | length > 0 %}
{% for interface in item.interfaces %}
    {
      "AggregatePortId": {{ interface.breakout_port_id | default(0)}},
      "ObjectType": "fabric.PortIdentifier",
      "PortId": {{ interface.port_id }},
      "SlotId": {{ interface.slot_id | default(1) }}
    }{% if not loop.last %},{% endif %}
{% endfor %}
{% endif %}
  ],
{% if item.tags | length > 0 %}
  "Tags": [
{% for tag in item.tags %}
    {
{% if tag.tag_type | default('KeyValue') == 'PathTag' %}
      "Key": {{ tag.key | tojson }},
      "Type": "PathTag"
{% else %}
      "Key": {{ tag.key | tojson }},
      "Type": "KeyValue",
      "Value": {{ tag.value | tojson }}
{% endif %}
    }{% if not loop.last %},{% endif %}
{% endfor %}
  ],
{% else %}
  "Tags": [],
{% endif %}
  "UserLabel": {{ item.user_label | default('') | tojson }},
  "VsanId": {{ item.vsan_id | default(100) | int }}
}